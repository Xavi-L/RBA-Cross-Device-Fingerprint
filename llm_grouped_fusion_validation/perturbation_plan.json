{
  "principle": "Only session runtime fields are perturbed. Stable identity fields and all test folds remain original.",
  "random_state": 42,
  "augmentations_per_row": 2,
  "runtime_perturbations": {
    "android_native_data.uptime_ms": {
      "mode": "multiplier",
      "low": 0.7,
      "high": 1.3
    },
    "android_native_data.avail_memory_gb": {
      "mode": "multiplier",
      "low": 0.85,
      "high": 1.15
    },
    "android_native_data.battery_level_pct": {
      "mode": "add_int",
      "low": -12,
      "high": 12,
      "min": 0,
      "max": 100
    },
    "android_native_data.battery_temp_celsius": {
      "mode": "add_float",
      "low": -2.5,
      "high": 2.5,
      "min": 15,
      "max": 55,
      "digits": 1
    },
    "android_native_data.battery_voltage_mv": {
      "mode": "add_int",
      "low": -80,
      "high": 80,
      "min": 3000,
      "max": 5000
    },
    "webview_data.bridge_latency_ms": {
      "mode": "multiplier",
      "low": 0.7,
      "high": 1.5
    },
    "web_data.compute_task_time_ms": {
      "mode": "multiplier",
      "low": 0.7,
      "high": 1.5
    }
  },
  "group_score_fields": [
    "native_web_score",
    "native_webview_score",
    "webview_web_score",
    "tri_layer_score",
    "physical_runtime_score",
    "attack_scenario_score"
  ]
}
